{
    "name": "surgiie/dusk-cli",
    "description": "A cli for using Laravel Dusk (Chrome Driver).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "intonate/tinker-zero": "^1.2",
        "laravel-zero/framework": "^11.0",
        "nunomaduro/laravel-console-dusk": "^1.13",
        "pestphp/pest": "^3.5.1",
        "spatie/invade": "^2.0",
        "symfony/yaml": "^6.2"
    },
    "require-dev": {
        "laravel/pint": "^1.2",
        "mockery/mockery": "^1.4.4"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nunomaduro/laravel-console-dusk"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest tests -c phpunit.xml.dist"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "dusk"
    ]
}
